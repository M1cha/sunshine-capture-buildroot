From eee43b4d12d6745546d0f4a149a7ca9df870dafb Mon Sep 17 00:00:00 2001
From: Michael Zimmermann <sigmaepsilon92@gmail.com>
Date: Tue, 24 Mar 2026 14:23:49 +0100
Subject: [PATCH] Buildroot

---
 cmake/compile_definitions/linux.cmake      | 22 +---------------------
 cmake/dependencies/common.cmake            |  2 +-
 cmake/dependencies/libevdev_Sunshine.cmake |  2 +-
 src/platform/linux/misc.cpp                |  8 --------
 4 files changed, 3 insertions(+), 31 deletions(-)

diff --git a/cmake/compile_definitions/linux.cmake b/cmake/compile_definitions/linux.cmake
index e4ed683f..3195f97a 100644
--- a/cmake/compile_definitions/linux.cmake
+++ b/cmake/compile_definitions/linux.cmake
@@ -164,14 +164,6 @@ if(X11_FOUND)
             "${CMAKE_SOURCE_DIR}/src/platform/linux/x11grab.cpp")
 endif()
 
-if(NOT ${CUDA_FOUND}
-        AND NOT ${WAYLAND_FOUND}
-        AND NOT ${X11_FOUND}
-        AND NOT (${LIBDRM_FOUND} AND ${LIBCAP_FOUND})
-        AND NOT ${LIBVA_FOUND})
-    message(FATAL_ERROR "Couldn't find either cuda, wayland, x11, (libdrm and libcap), or libva")
-endif()
-
 # tray icon
 if(${SUNSHINE_ENABLE_TRAY})
     pkg_check_modules(APPINDICATOR ayatana-appindicator3-0.1)
@@ -234,23 +226,11 @@ endif ()
 
 list(APPEND PLATFORM_TARGET_FILES
         "${CMAKE_SOURCE_DIR}/src/platform/linux/publish.cpp"
-        "${CMAKE_SOURCE_DIR}/src/platform/linux/graphics.h"
-        "${CMAKE_SOURCE_DIR}/src/platform/linux/graphics.cpp"
         "${CMAKE_SOURCE_DIR}/src/platform/linux/misc.h"
         "${CMAKE_SOURCE_DIR}/src/platform/linux/misc.cpp"
-        "${CMAKE_SOURCE_DIR}/src/platform/linux/audio.cpp"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/src/egl.c"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/src/gl.c"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/include/EGL/eglplatform.h"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/include/KHR/khrplatform.h"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/include/glad/gl.h"
-        "${CMAKE_SOURCE_DIR}/third-party/glad/include/glad/egl.h")
+        "${CMAKE_SOURCE_DIR}/src/platform/linux/audio.cpp")
 
 list(APPEND PLATFORM_LIBRARIES
         dl
         pulse
         pulse-simple)
-
-include_directories(
-        SYSTEM
-        "${CMAKE_SOURCE_DIR}/third-party/glad/include")
diff --git a/cmake/dependencies/common.cmake b/cmake/dependencies/common.cmake
index 97319be6..1b71abb3 100644
--- a/cmake/dependencies/common.cmake
+++ b/cmake/dependencies/common.cmake
@@ -24,7 +24,7 @@ pkg_check_modules(CURL REQUIRED libcurl)
 
 # miniupnp
 pkg_check_modules(MINIUPNP miniupnpc REQUIRED)
-include_directories(SYSTEM ${MINIUPNP_INCLUDE_DIRS})
+include_directories(${MINIUPNP_INCLUDE_DIRS})
 
 # ffmpeg pre-compiled binaries
 if(NOT DEFINED FFMPEG_PREPARED_BINARIES)
diff --git a/cmake/dependencies/libevdev_Sunshine.cmake b/cmake/dependencies/libevdev_Sunshine.cmake
index ca9e22dc..0e374b6a 100644
--- a/cmake/dependencies/libevdev_Sunshine.cmake
+++ b/cmake/dependencies/libevdev_Sunshine.cmake
@@ -40,7 +40,7 @@ if(EVDEV_INCLUDE_DIR AND EVDEV_LIBRARY)
     message(STATUS "Found libevdev library: ${EVDEV_LIBRARY}")
     message(STATUS "Found libevdev include directory: ${EVDEV_INCLUDE_DIR}")
 
-    include_directories(SYSTEM ${EVDEV_INCLUDE_DIR})
+    include_directories(${EVDEV_INCLUDE_DIR})
     list(APPEND PLATFORM_LIBRARIES ${EVDEV_LIBRARY})
 else()
     message(FATAL_ERROR "Couldn't find or fetch libevdev")
diff --git a/src/platform/linux/misc.cpp b/src/platform/linux/misc.cpp
index 9da87337..7459034f 100644
--- a/src/platform/linux/misc.cpp
+++ b/src/platform/linux/misc.cpp
@@ -27,7 +27,6 @@
 #include <unistd.h>
 
 // local includes
-#include "graphics.h"
 #include "misc.h"
 #include "src/config.h"
 #include "src/entry_handler.h"
@@ -897,9 +896,6 @@ namespace platf {
     // https://gitlab.freedesktop.org/mesa/mesa/-/merge_requests/30039
     set_env("AMD_DEBUG", "lowlatencyenc");
 
-    // These are allowed to fail.
-    gbm::init();
-
     window_system = window_system_e::NONE;
 #ifdef SUNSHINE_BUILD_WAYLAND
     if (std::getenv("WAYLAND_DISPLAY")) {
@@ -952,10 +948,6 @@ namespace platf {
       return nullptr;
     }
 
-    if (!gladLoaderLoadEGL(EGL_NO_DISPLAY) || !eglGetPlatformDisplay) {
-      BOOST_LOG(warning) << "Couldn't load EGL library"sv;
-    }
-
     return std::make_unique<deinit_t>();
   }
 
